# SBP QR provider mode:
# - mock:   generate local QR payload/image without bank API (default for testing)
# - http:   call external provider create endpoint (generic SBP provider)
# - tochka: Tochka Bank acquiring — produces a payment link/QR accepted by card, SBP, T-Pay
SBP_PROVIDER_MODE=mock
SBP_PROVIDER_CREATE_URL=
SBP_PROVIDER_API_KEY=
SBP_PROVIDER_TIMEOUT_SECONDS=10

# Protect webhook endpoint /api/v1/provider/webhook/sbp
# - mock/http providers may send:
#   - X-SBP-Signature: hex(hmac_sha256(body, secret))
#   - X-Webhook-Secret: <secret>
# - tochka provider sends the entire body as an RS256-signed JWT (no secret needed here)
SBP_WEBHOOK_SECRET=


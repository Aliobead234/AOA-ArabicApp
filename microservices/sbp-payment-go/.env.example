SUPABASE_URL=https://xmhqgwrwezonofhvukpp.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhtaHFnd3J3ZXpvbm9maHZ1a3BwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI3MDg1NDEsImV4cCI6MjA4ODI4NDU0MX0.r3AT-VgxMz-9x7km0N7gvlYPBv-eaI37--F8Ykd9Pgk
# NOTE: SUPABASE_URL and SUPABASE_ANON_KEY must belong to the same project used by the frontend client.
CORS_ALLOW_ORIGINS=http://localhost:5175/

# SBP recipient shown to users in transfer instructions
SBP_RECIPIENT_PHONE=+79013622325
SBP_RECIPIENT_BANK=TBank
SBP_RECIPIENT_NAME=AOA Flashcards

# SBP QR provider mode:
# - mock:   generate local QR payload/image without bank API (default for testing)
# - http:   call external provider create endpoint (generic SBP provider)
# - tochka: Tochka Bank acquiring — produces a payment link/QR accepted by card, SBP, T-Pay
SBP_PROVIDER_MODE=mock
SBP_PROVIDER_CREATE_URL=
SBP_PROVIDER_API_KEY=
SBP_PROVIDER_TIMEOUT_SECONDS=10

# Protect webhook endpoint /api/v1/provider/webhook/sbp
# - mock/http providers may send:
#   - X-SBP-Signature: hex(hmac_sha256(body, secret))
#   - X-Webhook-Secret: <secret>
# - tochka provider sends the entire body as an RS256-signed JWT (no secret needed here)
SBP_WEBHOOK_SECRET=

# ── Tochka Bank acquiring (required when SBP_PROVIDER_MODE=tochka) ──────────
# JWT Bearer token from Tochka internet banking → Settings → API
TOCHKA_JWT_TOKEN=
# Your Tochka customer code (from accounts API, not from JWT)
TOCHKA_CUSTOMER_CODE=
# Tochka bank BIC code (default 044525104)
TOCHKA_BANK_CODE=044525104
# Settlement account ID — format: account_number/bik
TOCHKA_ACCOUNT_ID=
# Payment modes: sbp, card, tinkoff, dolyame (comma-separated)
TOCHKA_PAYMENT_MODE=sbp
# URL of Tochka's RS256 public key used to verify incoming webhook JWTs
TOCHKA_WEBHOOK_KEY_URL=https://enter.tochka.com/doc/openapi/static/keys/public

# Payment flow controls
ORDER_TTL_MINUTES=30
MONTHLY_DURATION_DAYS=30
AUTO_VERIFY_ENABLED=false
AUTO_VERIFY_DELAY_SECONDS=3

# Required for manual verification endpoint: POST /api/v1/admin/orders/:id/verify
ADMIN_TOKEN=change-me

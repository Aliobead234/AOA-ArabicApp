# SBP recipient shown to users in transfer instructions
SBP_RECIPIENT_PHONE=+79013622325
SBP_RECIPIENT_BANK=TBank
SBP_RECIPIENT_NAME=AOA Flashcards

# SBP QR provider mode:
# - mock: generate local QR payload/image without bank API
# - http: call external provider create endpoint
SBP_PROVIDER_MODE=mock
SBP_PROVIDER_CREATE_URL=
SBP_PROVIDER_API_KEY=
SBP_PROVIDER_TIMEOUT_SECONDS=10

# Protect webhook endpoint /api/v1/provider/webhook/sbp
# Provider may send either:
# - X-SBP-Signature: hex(hmac_sha256(body, secret))
# - X-Webhook-Secret: <secret>
SBP_WEBHOOK_SECRET=

# Payment flow controls
ORDER_TTL_MINUTES=30
MONTHLY_DURATION_DAYS=30
AUTO_VERIFY_ENABLED=false
AUTO_VERIFY_DELAY_SECONDS=3

# Required for manual verification endpoint: POST /api/v1/admin/orders/:id/verify
ADMIN_TOKEN=change-me
